# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token
DATABASE_URL=https://your-project.supabase.co
SERVICE_KEY=your-supabase-service-role-key

# Super-admin Telegram ID — REQUIRED, server refuses to start without it
SUPER_ADMIN_TG_ID=your-telegram-id

# ── Recommended ───────────────────────────────────────────────────────────────
# Secure random string for Telegram bot webhook URL (rotate without changing BOT_TOKEN)
WEBHOOK_SECRET=your-random-webhook-secret

# Your bot's @username (used for referral links)
BOT_USERNAME=your_bot_username

# Public URL where this API is hosted (Railway auto-registers the webhook when set)
RAILWAY_PUBLIC_DOMAIN=your-app.railway.app

# ── Frontend / webapp ─────────────────────────────────────────────────────────
# URL of the deployed Vite frontend (used for QR code target URLs)
WEBAPP_URL=https://your-webapp.example.com

# URL of this backend (without trailing slash) — used by the React frontend
VITE_API_URL=https://your-app.railway.app

# Super-admin Telegram ID for the frontend (same value as SUPER_ADMIN_TG_ID)
VITE_SUPER_ADMIN_TG_ID=your-telegram-id

# ── Operator endpoints (optional) ─────────────────────────────────────────────
# Secret key for B2B operator topup endpoints; leave empty to disable them
OPERATOR_SECRET=

# ── GEO economics ─────────────────────────────────────────────────────────────
# Conversion rate: how many UZS per 1 GEO
GEO_RATE=1000

# ── Business top-up payment details ───────────────────────────────────────────
TOPUP_CARD_NUMBER=9800 1000 2000 3000
TOPUP_CARD_HOLDER=GeoEarn
TOPUP_BANK=Payme

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
